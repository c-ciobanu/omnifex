{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "watch": "docker compose up"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1013.0",
    "@aws-sdk/s3-request-presigner": "3.1013.0",
    "@bull-board/api": "6.20.6",
    "@bull-board/hono": "6.20.6",
    "@googleapis/books": "8.0.1",
    "@hono/node-server": "1.19.11",
    "@omnifex/auth": "workspace:*",
    "@omnifex/db": "workspace:*",
    "@omnifex/orpc": "workspace:*",
    "@orpc/server": "catalog:orpc",
    "@t3-oss/env-core": "catalog:",
    "bullmq": "5.71.0",
    "date-fns": "4.1.0",
    "dotenv": "17.3.1",
    "hono": "4.12.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@omnifex/eslint-config": "workspace:*",
    "@omnifex/prettier-config": "workspace:*",
    "@omnifex/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:eslint",
    "prettier": "catalog:",
    "tsdown": "0.21.4",
    "tsx": "4.21.0",
    "typescript": "catalog:"
  },
  "prettier": "@omnifex/prettier-config"
}
